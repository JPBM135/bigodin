    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
